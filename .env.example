DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Groq (AI correction + assistente — console.groq.com)
GROQ_API_KEY=gsk_xxxx

# Anthropic Claude (substituído pelo Groq — não usar)
# ANTHROPIC_API_KEY=sk-ant-xxxx

# OpenAI (legacy — não usado)
# OPENAI_API_KEY=sk-xxxx

# Stripe — Plano Pro, 3 preços (mensal recorrente + semestral/anual à vista)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxx
STRIPE_PRICE_PRO_SEMESTRAL_UPFRONT=price_xxxx
STRIPE_PRICE_PRO_ANNUAL_UPFRONT=price_xxxx

# Email (Resend — para notificações)
RESEND_API_KEY=re_xxxx

# Segurança — OBRIGATÓRIO em produção.
# Assina os tokens de sessão (HMAC). Sem isso, a app recusa iniciar em produção.
# Gere uma string aleatória forte, ex: openssl rand -base64 48
SESSION_SECRET=troque-por-uma-string-aleatoria-de-32-ou-mais-caracteres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
